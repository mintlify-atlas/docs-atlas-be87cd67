    "GET /api/admin/election-day-graph",
    "GET /api/admin/get-constituencies/reports",
    "GET /api/admin/call-center/list",
    "GET /api/user/voters-list",
    "POST /api/user/surveys",
    "GET /api/manager/voters-list",
    "POST /api/upload-ocr-image",
    "GET /api/voters/duplicate"
  ]
