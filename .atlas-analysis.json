  "keyFeatures": [
    "JWT-based authentication with role-based access control (Admin, Manager, User)",
    "Comprehensive voter registry with search, filtering, and import via Excel/CSV",
    "Field survey system capturing voter demographics, political preferences, and contact info",
    "Voter card tracking with election-day turnout graphs and party-breakdown reports",
    "Call center management for voter outreach and contact logging",
    "Unregistered voter tracking with notes and contact history",
    "Constituency and polling station management with geospatial map support",
    "OCR image processing for voter card data extraction",
    "Activity logging with GeoIP tracking for audit trails",
    "PDF and Excel export for all major voter and report datasets"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
    "POST /api/auth/register",
    "POST /api/auth/logout",
    "GET /api/admin/voters",
    "POST /api/admin/voters_list/import",
